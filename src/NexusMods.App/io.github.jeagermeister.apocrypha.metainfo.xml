<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <!-- See https://www.freedesktop.org/software/appstream/docs/chap-Metadata.html#spec-component-filespec -->

    <id>io.github.jeagermeister.apocrypha</id>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0-only</project_license>

    <name>Apocrypha</name>
    <summary>The Linux-first mod platform</summary>

    <developer id="io.github.jeagermeister">
        <name>The Apocrypha Project</name>
    </developer>

    <description>
        <p>Apocrypha is a Linux-first mod platform: one app for mods from Nexus Mods, Thunderstore, and beyond, with git-like loadouts you can diff, revert, and trust. Canon is just the beginning.</p>
        <p>An independent continuation of the archived Nexus Mods App (GPL-3.0).</p>
    </description>

    <branding>
        <color type="primary" scheme_preference="light">#fafafa</color>
        <color type="primary" scheme_preference="dark">#1d1d21</color>
    </branding>

    <launchable type="desktop-id">io.github.jeagermeister.apocrypha.desktop</launchable>

    <url type="homepage">https://github.com/Jeagermeister/Apocrypha</url>
    <url type="bugtracker">https://github.com/Jeagermeister/Apocrypha/issues</url>
    <url type="vcs-browser">https://github.com/Jeagermeister/Apocrypha</url>

    <content_rating type="oars-1.0">
        <content_attribute id="social-info">intense</content_attribute>
    </content_rating>

    <categories>
        <category>Game</category>
    </categories>

    <recommends>
        <memory>1024</memory>

        <internet>always</internet>
        <display_length compare="ge">360</display_length>

        <id version="1.0" compare="ge">com.valvesoftware.Steam</id>
    </recommends>

    <supports>
        <id version="1.0" compare="ge">com.heroicgameslauncher.hgl</id>

        <control>gamepad</control>
    </supports>

    <!-- NOTE(erri120): we use a script to turn GitHub releases into a supported format -->
    <releases type="external"/>

</component>
